      },
      "pokemon_moba_audino": {
        "name": "Audino",
        "attack": "Pound: Flops into an enemy for light physical Normal damage.",
        "skill": "Protect: Redirects Pokemon damage from an allied Pokemon to Audino and ignores new damaging statuses for a short duration.",
