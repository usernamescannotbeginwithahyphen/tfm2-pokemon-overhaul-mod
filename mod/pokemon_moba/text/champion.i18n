      },
      "pokemon_moba_gallade": {
        "name": "Gallade",
        "attack": "Sacred Sword: Slashes an enemy for physical Fighting damage.",
        "skill": "Future Sight: Predicts one enemy, reducing that enemy's Pokemon damage to Gallade for a short duration.",
