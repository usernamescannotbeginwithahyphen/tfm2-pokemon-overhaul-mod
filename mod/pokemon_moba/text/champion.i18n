{
  "en": {
    "description": {
      "pokemon_moba_pikachu": {
        "name": "Pikachu",
        "attack": "Spark: Fires a short-ranged electric projectile for light special damage. Deals much more damage to Paralyzed enemies.",
        "skill": "Volt Tackle: Dashes through the target, dealing light physical Electric damage that scales with AP.",
        "skill2": "Thunder Wave: Hits an enemy with a weak Electric blast and applies Paralysis for 30 seconds. Each second, Paralysis has a 33% chance to stun for 1 second.",
        "ult": "Thunder: Calls down a powerful Electric strike on a distant target, dealing heavy special damage.",
        "passive": "Static Shock: Pikachu's attacks against Paralyzed enemies deal substantially increased damage."
      },
      "pokemon_moba_charizard": {
        "name": "Charizard",
        "attack": "Flamethrower: Continuously breathes a short cone of fire while moving, dealing low special damage to enemies in front of Charizard.",
        "skill": "Dragon Breath: Breathes a stronger Dragon-type cone while moving, dealing repeated special damage in front of Charizard.",
        "skill2": "Fire Blast: Launches a long-range fire projectile that stops on the first enemy hit, dealing heavy special damage.",
        "ult": "Inferno: After a long windup, erupts a small target area in flame, dealing massive special damage.",
        "passive": "Blaze: Enemies hit repeatedly by Flamethrower or Dragon Breath are Burned. Burn deals stacking damage over time for 15 seconds. Fire, Ground, and Water types cannot be Burned."
      },
      "pokemon_moba_blastoise": {
        "name": "Blastoise",
        "attack": "Hydro Pump: Fires two cannon shots in immediate succession, dealing Water damage that scales with attack damage.",
        "skill": "Rapid Spin: Withdraws into the shell, gaining movement speed, heavy damage reduction, and CC immunity while damaging nearby enemies.",
        "skill2": "Aqua Tail: Spins into a close-range tail strike, dealing light Water damage and knocking the target away.",
        "ult": "Hydro Cannon: Fires a narrow long-range cannon beam, dealing heavy Water damage to all enemies in the line.",
        "passive": "Mega Launcher: Consecutive Hydro Pump hits against the same enemy build crit chance. Crit chance above 100% becomes bonus crit damage."
      },
      "pokemon_moba_venusaur": {
        "name": "Venusaur",
        "attack": "Tackle: Slams into a nearby enemy for light physical damage.",
        "skill": "Vine Whip: Sends vines in a line. The first enemy hit is bound in place with Venusaur for a moderate duration.",
        "skill2": "Leech Seed: Sends roots along the ground. The first enemy hit is tethered, taking damage over time while healing Venusaur. The tether breaks if they move too far apart and can spread to enemies crossing the roots.",
        "ult": "Sludge Wave: Sends a slow Poison wave through a line. Enemies hit are heavily slowed and receive 5 stacks of Poison. Poison, Grass, and Steel types cannot be Poisoned.",
        "passive": "Tangling Vines: When a crowd controlled enemy is near Venusaur, nearby allies gain attack speed and attack damage. Venusaur's nearby allies also deal increased damage to crowd controlled enemies."
      },
      "pokemon_moba_eevee": {
        "name": "Eevee",
        "attack": "Tackle: Slams into a nearby enemy for very light physical damage.",
        "skill": "Baby-Doll Eyes: Lowers the target's attack, then protects Eevee and the closest nearby ally from incoming damage.",
        "skill2": "Wish: Eevee channels a heal into a targeted ally. Moving ends the channel early and heals for the time channeled.",
        "ult": "Baton Pass: Transfers most of Eevee's current combat stats to a targeted ally for 30 seconds, heavily weakening Eevee for the same duration.",
        "passive": "Helping Hand: Nearby allied champions gain increased stats and reduced skill cooldowns."
      },
      "pokemon_moba_jolteon": {
        "name": "Jolteon",
        "attack": "Pin Missile: Fires three fast Bug-type needles at a short-ranged target, dealing physical damage.",
        "skill": "Sand Attack: Lowers a target's attack damage and attack speed for 10 seconds.",
        "skill2": "Thunder Shock: Shocks a single enemy for Electric damage that scales with attack damage and ability power.",
        "ult": "Thunder Fang: Jolteon leaps to a target and bites for heavy physical Electric damage. Surviving targets have a 30% chance to be Paralyzed.",
        "passive": "Eeveelution: If at least one other allied or enemy Pokemon has the Eeveelution passive, gains +2% combat stats for each other Eeveelution passive carrier."
      },
      "pokemon_moba_flareon": {
        "name": "Flareon",
        "attack": "Ember: Fires a short-range Fire attack for light special damage. Has a 10% chance to Burn for 3 seconds.",
        "skill": "Fire Spin: Spins in place, damaging and knocking back nearby enemies. Has a 10% chance to Burn for 5 seconds.",
        "skill2": "Flame Wheel: Sends a spinning Fire wheel forward through enemies, dealing special damage. Has a 10% chance to Burn for 10 seconds.",
        "ult": "Fire Fang: Flareon leaps to a target and bites for heavy special Fire damage. Surviving targets have a 30% chance to be Burned.",
        "passive": "Eeveelution: If at least one other allied or enemy Pokemon has the Eeveelution passive, gains +2% combat stats for each other Eeveelution passive carrier."
      },
      "pokemon_moba_vaporeon": {
        "name": "Vaporeon",
        "attack": "Water Gun: Fires a thin long-range Water line, dealing light special damage to enemies in the path.",
        "skill": "Growl: Lowers a target's attack for 5 seconds. The attack reduction scales with Vaporeon's defense.",
        "skill2": "Water Pulse: Fires a medium-range Water projectile that stops on the first enemy hit, dealing moderate special damage.",
        "ult": "Aqua Ring: Creates a short-range water ring around Vaporeon, rapidly healing nearby allies while lowering nearby enemies' attack.",
        "passive": "Eeveelution: If at least one other allied or enemy Pokemon has the Eeveelution passive, gains +2% combat stats for each other Eeveelution passive carrier."
      },
      "pokemon_moba_leafeon": {
        "name": "Leafeon",
        "attack": "Razor Leaf: Throws twin sharp leaves at a target for physical Grass damage. Has a 15% chance to Bleed, increased to 50% against jungle camps.",
        "skill": "Magical Leaf: Throws a sure-striking leaf for physical Grass damage that bypasses Pokemon type damage modifiers.",
        "skill2": "Leaf Blade: Slashes a nearby enemy for heavy physical Grass damage and applies Bleed.",
        "ult": "Leaf Storm: Calls down a small storm of razor leaves for massive physical Grass damage. Leafeon is slowed afterward.",
        "passive": "Eeveelution: If at least one other allied or enemy Pokemon has the Eeveelution passive, gains +2% combat stats for each other Eeveelution passive carrier."
      },
      "pokemon_moba_glaceon": {
        "name": "Glaceon",
        "attack": "Ice Shard: Fires a damaging Ice projectile at a target, dealing physical damage.",
        "skill": "Snowscape: Covers a target area in snow for 5 seconds. Enemies inside take light physical damage over time, are disarmed and slowed, and have a 25% chance each second to be Frozen.",
        "skill2": "Ice Fang: Glaceon leaps to a target and bites for physical Ice damage. Surviving targets have a 25% chance to be Frozen.",
        "ult": "Blizzard: Calls down a larger storm that deals heavy physical damage over time and continuously Freezes enemies inside.",
        "passive": "Eeveelution: If at least one other allied or enemy Pokemon has the Eeveelution passive, gains +2% combat stats for each other Eeveelution passive carrier."
      },
      "pokemon_moba_umbreon": {
        "name": "Umbreon",
        "attack": "Bite: Bites a nearby enemy for moderate physical Dark damage.",
        "skill": "Snarl: Damages nearby enemies very lightly and lowers their defense. The defense reduction scales with Umbreon's attack damage.",
        "skill2": "Dark Pulse: Fires a medium-range Dark projectile that stops on the first enemy hit, dealing physical damage. If it lands, Umbreon gains Shadow Veil for 3 seconds.",
        "ult": "Crunch: Umbreon leaps to a target and bites for heavy physical Dark damage. Surviving targets have a 30% chance to be disarmed for 3 seconds.",
        "passive": "Eeveelution: If at least one other allied or enemy Pokemon has the Eeveelution passive, gains +2% combat stats for each other Eeveelution passive carrier."
      },
