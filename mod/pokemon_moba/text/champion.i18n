      "pokemon_moba_cryogonal": {
        "name": "Cryogonal",
        "attack": "Ice Shard: Fires an Ice projectile at an enemy, dealing special damage.",
        "skill": "Icy Wind: Sends an icy line across the battlefield, damaging enemies it passes through and carrying a chance to Freeze.",
        "skill2": "Freeze-Dry: Chills a single enemy for special damage. This move is additionally super effective against Water-type Pokemon.",
        "ult": "Ice Beam: Fires a long Ice beam that damages enemies in its path and has a high chance to Freeze.",
        "passive": "Immunity: Cryogonal cannot be Burned or Poisoned."
      },
      "pokemon_moba_vanilluxe": {
        "name": "Vanilluxe",
        "attack": "Icicle Spear: Launches a long-range Ice projectile at an enemy, dealing special damage.",
        "skill": "Chilling Water: Sends a Water line across the battlefield, damaging enemies it passes through and carrying a chance to Freeze.",
        "skill2": "Frost Breath: Blasts a far-reaching Ice cone, damaging and Freezing enemies caught in it.",
        "ult": "Sheer Cold: Emits a freezing blast around Vanilluxe, heavily damaging enemies and Freezing enemies and allies caught in the area.",
        "passive": "Snow Patrol: Vanilluxe's attacks critically strike Frozen enemies."
      },
      "pokemon_moba_skarmory": {
        "name": "Skarmory",
        "attack": "Peck: Pecks a nearby enemy, dealing physical Flying damage.",
        "skill": "Roost: Temporarily becomes pure Steel-type and rapidly heals.",
        "skill2": "Dual Wingbeat: Slashes an enemy twice with its wings, dealing physical Flying damage on each hit.",
        "ult": "Fly: Flies to an allied Pokemon anywhere on the map, dealing physical Flying splash damage to enemies near the landing point.",
        "passive": "Sturdy: Once every 5 minutes, direct damage that would reduce Skarmory to 0 HP leaves it at 1 HP instead. Damage-over-time does not trigger Sturdy."
      },
      "pokemon_moba_houndoom": {
        "name": "Houndoom",
        "attack": "Ember: Fires a small Fire projectile, dealing special damage.",
        "skill": "Foul Play: Deals Dark special damage, increased if Houndoom has avoided damage recently.",
        "skill2": "Howl: Stuns an enemy briefly and lowers their defense.",
        "ult": "Inferno: Erupts a target area in flames, dealing Fire special damage and Burning enemies.",
        "passive": "Intimidate: Nearby enemies have reduced attack."
      },
      "pokemon_moba_arbok": {
        "name": "Arbok",
        "attack": "Poison Sting: Strikes a nearby enemy for physical Poison damage. Every second hit applies Miasma.",
        "skill": "Coil: Dashes through enemies, applying Miasma. The primary target is stunned, damaged, and shoved away while Arbok becomes briefly untargetable.",
        "skill2": "Spit Up: Covers an area in bile, applying Miasma and slowing enemies.",
        "ult": "Venoshock: Detonates all Miasma stacks around Arbok for physical Poison damage and applies Poison.",
        "passive": "Dripping Fangs: Every 10 Miasma stacks applies Poison. Enemies that die with Miasma spread their stacks nearby."
      },
